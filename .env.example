# ──────────────────────────────────────────
# Paper Collector — Environment Configuration
# ──────────────────────────────────────────
# Copy this to .env and fill in your values.

# --- Data Directory ---
# Root directory where collections are stored.
# Default: ./collections (relative to project root)
PAPER_COLLECTOR_DATA_DIR=./collections

# --- API Keys & Credentials ---
# arXiv: No key required — use polite delay
ARXIV_DELAY_SECONDS=3.0

# OpenAlex: Get key at https://openalex.org/settings/api
OPENALEX_API_KEY=LdRpWlN1ZywkeP5gf4uTy6

# Crossref: Email for polite pool (optional, recommended)
CROSSREF_EMAIL=ikpark@road-lab.com

# Unpaywall: Email required for API access
UNPAYWALL_EMAIL=ikpark@road-lab.com

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
